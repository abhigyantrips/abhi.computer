{
	"$schema": "node_modules/wrangler/config-schema.json",

	"name": "abhi-computer",
	"main": "@astrojs/cloudflare/entrypoints/server",

	"compatibility_date": "2026-06-13",
	"compatibility_flags": ["global_fetch_strictly_public"],

	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
	},

	"kv_namespaces": [
		{
			"binding": "SESSIONS",
			"id": "8da3914079ef4549b28d920b7621482b",
		}
	],

	"observability": {
		"enabled": true,
	},

	"preview_urls": false,
	"workers_dev": false,
	"routes": [
		{
			"pattern": "abhi.computer",
			"custom_domain": true,
		},
	],
}
