---
import BaseHead from "@/components/base-head.astro";
import Container from "@/components/container.astro";
import Header from "@/components/header.astro";
import Footer from "@/components/footer.astro";

import "@/styles/global.css";

interface Props {
	title: string;
	description: string;
	icon?: string;
	color?: string;
	link?: string;
	confidence?: number;
}

const { title, description, icon, color, link, confidence } = Astro.props;

const confidenceColors = ["#991b1b", "#c2410c", "#ca8a04", "#65a30d", "#15803d"];
const activeConfidenceColor = confidenceColors[(confidence ?? 1) - 1];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead />
	</head>
	<body class="font-mono">
		<Header />
		<main class="flex min-h-[calc(100vh-(--spacing(38)))] flex-1 flex-col pb-36">
			<Container size="md">
				<div class="flex flex-col gap-2 pt-48">
					{
						icon && (
							<div class="flex items-start justify-between">
								<div
									class="tag-archive-mark"
									style={`--tag-color: ${color ?? "#111827"}`}
									aria-hidden="true"
								>
									<img
										src={icon}
										alt=""
									/>
								</div>
								{typeof confidence === "number" && (
									<div
										class="flex flex-col items-end gap-1.5"
										aria-label={`Confidence: ${confidence} out of 5`}
									>
										<span class="text-[10px] font-semibold tracking-[0.18em] text-gray-500 uppercase">
											Confidence
										</span>
										<div class="flex gap-1.5">
											{Array.from({ length: 5 }, (_, i) => {
												const filled = i < confidence;
												const isFirst = i === 0;
												const isLast = i === 4;

												return (
													<div
														class:list={["h-6 w-5", !filled && "bg-gray-200"]}
														style={{
															backgroundColor: filled ? activeConfidenceColor : undefined,
															clipPath: isFirst
																? "polygon(18% 0, 100% 0, 100% 100%, 0 100%, 0 18%)"
																: isLast
																	? "polygon(0 0, 100% 0, 100% 82%, 82% 100%, 0 100%)"
																	: undefined,
														}}
													/>
												);
											})}
										</div>
									</div>
								)}
							</div>
						)
					}
					<div class="flex items-center gap-2">
						<h1 class="text-3xl font-bold">{title}</h1>
						{
							link && (
								<a
									class="mt-1.5 size-6 text-black"
									href={link}
									aria-label={`Open ${title} website`}
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 256 256"
									>
										<>
											<rect
												width="256"
												height="256"
												fill="none"
											/>
											<line
												x1="64"
												y1="192"
												x2="192"
												y2="64"
												fill="none"
												stroke="currentColor"
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="16"
											/>
											<polyline
												points="88 64 192 64 192 168"
												fill="none"
												stroke="currentColor"
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="16"
											/>
										</>
									</svg>
								</a>
							)
						}
					</div>
					<p class="text-gray-600">{description}</p>
				</div>
				<hr class="my-6 border-t-2 border-gray-300" />
				<slot />
			</Container>
		</main>
		<Footer />
	</body>
</html>

<style>
	.tag-archive-mark {
		align-items: center;
		background: var(--tag-color);
		clip-path: polygon(18% 0, 100% 0, 100% 82%, 82% 100%, 0 100%, 0 18%);
		color: white;
		display: inline-flex;
		height: 3.25rem;
		justify-content: center;
		margin-bottom: 0.75rem;
		width: 3.25rem;
	}

	.tag-archive-mark img {
		height: 1.85rem;
		width: 1.85rem;
	}

	.external-link-button:hover {
		background: var(--tag-color, var(--color-text));
		color: white;
		text-decoration: none;
	}

	.external-link-button svg {
		height: 1.1rem;
		width: 1.1rem;
	}
</style>
