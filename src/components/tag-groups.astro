---
import type { CollectionEntry } from "astro:content";

type TagEntry = CollectionEntry<"tech"> | CollectionEntry<"fields">;

interface TagGroup {
	label: string;
	entries: TagEntry[];
	hrefPrefix: string;
}

interface Props {
	groups: TagGroup[];
}

const groups = Astro.props.groups.filter((group) => group.entries.length > 0);
---

{
	groups.length > 0 && (
		<div class="not-prose flex flex-col gap-4">
			{groups.map((group) => (
				<section class="flex flex-col gap-2" aria-label={group.label}>
					<h2 class="text-xs font-semibold tracking-[0.18em] text-gray-500 uppercase">
						{group.label}
					</h2>
					<div class="flex flex-wrap gap-2">
						{group.entries.map((tag) => (
							<a
								class="tag-pill p-category"
								href={`${group.hrefPrefix}/${tag.id}`}
								title={tag.data.description}
								style={`--tag-color: ${tag.data.color}`}
							>
								<span>{tag.data.name}</span>
							</a>
						))}
					</div>
				</section>
			))}
		</div>
	)
}

<style>
	.tag-pill {
		align-items: center;
		background: color-mix(in srgb, var(--tag-color) 11%, transparent);
		border: 1px solid color-mix(in srgb, var(--tag-color) 55%, transparent);
		color: var(--color-text);
		display: inline-flex;
		font-size: 0.75rem;
		line-height: 1;
		padding: 0.375rem 0.55rem;
		text-decoration: none;
	}

	.tag-pill:hover {
		background: var(--tag-color);
		color: white;
		text-decoration: none;
	}
</style>
