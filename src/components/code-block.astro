---
const rawProps = Astro.props as Record<string, unknown>;
const { class: astroClass, className, style, ...attrs } = rawProps;

const classes = [astroClass, className]
	.filter((value): value is string => typeof value === "string" && value.length > 0)
	.join(" ");
const language = typeof attrs["data-language"] === "string" ? attrs["data-language"] : "code";
---

<figure class="not-prose code-block">
	<div class="code-block__bar">
		<span class="code-block__label" data-code-block-label>{language}</span>
		<div class="code-block__actions">
			<button
				class="code-block__button"
				type="button"
				data-code-block-wrap
				aria-label="Wrap lines"
				aria-pressed="false"
				title="Wrap lines"
			>
				<i class="hn hn-align-left" aria-hidden="true"></i>
			</button>
			<button
				class="code-block__button"
				type="button"
				data-code-block-copy
				aria-label="Copy code"
				title="Copy code"
			>
				<i class="hn hn-copy" aria-hidden="true"></i>
			</button>
		</div>
	</div>
	<pre {...attrs} class={classes} style={style}><slot /></pre>
</figure>

<script>
	function enhanceCodeBlocks() {
		const blocks = document.querySelectorAll(".code-block");

		for (const block of blocks) {
			if (block.hasAttribute("data-code-block-ready")) continue;

			const pre = block?.querySelector("pre");
			const code = pre?.querySelector("code");
			const label = block?.querySelector("[data-code-block-label]");
			const copyButton = block?.querySelector("[data-code-block-copy]");
			const wrapButton = block?.querySelector("[data-code-block-wrap]");
			const language =
				pre?.dataset.language ||
				[...(code?.classList ?? [])]
					.find((className) => className.startsWith("language-"))
					?.replace("language-", "");

			if (label && language) {
				label.textContent = language;
			}

			block.setAttribute("data-code-block-ready", "true");
			wrapButton?.addEventListener("click", () => {
				const shouldWrap = !block.hasAttribute("data-wrap");

				block.toggleAttribute("data-wrap", shouldWrap);
				wrapButton.setAttribute("aria-pressed", String(shouldWrap));
				wrapButton.setAttribute("aria-label", shouldWrap ? "Disable line wrap" : "Wrap lines");
				wrapButton.setAttribute("title", shouldWrap ? "Disable line wrap" : "Wrap lines");
			});

			copyButton?.addEventListener("click", async () => {
				const text = code?.textContent ?? "";

				if (!text || !navigator.clipboard) return;

				await navigator.clipboard.writeText(text);
				copyButton.setAttribute("aria-label", "Copied");
				copyButton.setAttribute("title", "Copied");
				copyButton.setAttribute("data-copied", "true");

				window.setTimeout(() => {
					copyButton.setAttribute("aria-label", "Copy code");
					copyButton.setAttribute("title", "Copy code");
					copyButton.removeAttribute("data-copied");
				}, 1600);
			});
		}
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", enhanceCodeBlocks);
	} else {
		enhanceCodeBlocks();
	}
</script>

<style>
	.code-block {
		--code-block-bg: #16161d;
		--code-block-border: #2a2a37;
		--code-block-muted: #9a9aaf;
		--code-block-accent: #dca561;

		margin: 1.5rem 0;
		overflow: hidden;
		border: 1px solid var(--code-block-border);
		border-radius: 0;
		background: var(--code-block-bg);
		box-shadow: 0 1px 0 rgb(255 255 255 / 0.04) inset;
	}

	.code-block__bar {
		display: flex;
		min-height: 2.25rem;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		border-bottom: 1px solid var(--code-block-border);
		background: #2f2f36;
		padding: 0.35rem 0.5rem 0.35rem 0.85rem;
	}

	.code-block__label {
		color: var(--code-block-muted);
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0;
		line-height: 1;
		text-transform: uppercase;
	}

	.code-block__actions {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.code-block__button {
		display: inline-grid;
		width: 1.75rem;
		height: 1.75rem;
		place-items: center;
		border: 1px solid transparent;
		border-radius: 0;
		color: var(--code-block-muted);
		background: transparent;
		cursor: pointer;
		font-size: 1rem;
		line-height: 1;
		transition:
			background-color 140ms ease,
			border-color 140ms ease,
			color 140ms ease;
	}

	.code-block__button:hover,
	.code-block__button:focus-visible,
	.code-block__button[aria-pressed="true"] {
		border-color: rgb(220 165 97 / 0.34);
		background: rgb(220 165 97 / 0.12);
		color: var(--code-block-accent);
		outline: none;
	}

	.code-block__button[data-copied="true"] {
		border-color: rgb(152 187 108 / 0.42);
		background: rgb(152 187 108 / 0.14);
		color: #98bb6c;
	}

	.code-block :global(.hn) {
		line-height: 1;
	}

	pre {
		margin: 0;
		border-radius: 0;
		background: transparent !important;
		padding: 1rem;
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: 0.86rem;
		line-height: 1.65;
		tab-size: 2;
	}

	pre :global(code) {
		display: block;
		min-width: max-content;
		background: transparent;
		padding: 0;
		font-family: inherit;
		font-size: inherit;
		line-height: inherit;
	}

	.code-block[data-wrap] pre {
		overflow-x: visible;
		white-space: pre-wrap;
		word-break: break-word;
	}

	.code-block[data-wrap] pre :global(code) {
		min-width: 0;
		white-space: inherit;
	}

	@media (max-width: 640px) {
		.code-block {
			margin-right: -0.75rem;
			margin-left: -0.75rem;
			border-right-width: 0;
			border-left-width: 0;
			border-radius: 0;
		}
	}
</style>
