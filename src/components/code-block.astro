---
import { parseCodeMeta } from "@/lib/code-meta";
import type { HTMLAttributes } from "astro/types";

type PreProps = HTMLAttributes<"pre"> & {
	"data-meta"?: string;
};

const { class: astroClass, className, style, "data-meta": dataMeta, ...attrs } =
	Astro.props as PreProps;

const classes = [astroClass, className]
	.filter((value): value is string => typeof value === "string" && value.length > 0)
	.join(" ");

const language = typeof attrs["data-language"] === "string" ? attrs["data-language"] : "code";
const { filename } = parseCodeMeta(typeof dataMeta === "string" ? dataMeta : undefined);
const label = filename ?? language;
---

<figure
	class="group not-prose code-block my-6 overflow-hidden border border-black/15 max-sm:-mx-3 max-sm:border-x-0"
	data-code-block-filename={filename || undefined}
>
	<div
		class="flex min-h-9 items-stretch justify-between bg-black/6"
	>
		<span
			class="flex items-center px-3.5 font-mono text-[0.72rem] font-bold text-zinc-800 uppercase"
			data-code-block-label
		>
			{label}
		</span>
		<div class="flex items-stretch">
			<button
				class="inline-grid w-9 place-items-center text-zinc-800 hover:bg-amber-400 hover:text-amber-950 focus-visible:bg-amber-400 focus-visible:text-amber-950 focus-visible:outline-none aria-pressed:bg-amber-400 aria-pressed:text-amber-950"
				type="button"
				data-code-block-wrap
				aria-label="Wrap lines"
				aria-pressed="false"
				title="Wrap lines"
			>
				<svg
					class="size-4"
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 256 256"
					aria-hidden="true"
					><rect width="256" height="256" fill="none"></rect><line
						x1="40"
						y1="64"
						x2="216"
						y2="64"
						fill="none"
						stroke="currentColor"
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="16"></line><line
						x1="40"
						y1="104"
						x2="168"
						y2="104"
						fill="none"
						stroke="currentColor"
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="16"></line><line
						x1="40"
						y1="144"
						x2="216"
						y2="144"
						fill="none"
						stroke="currentColor"
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="16"></line><line
						x1="40"
						y1="184"
						x2="168"
						y2="184"
						fill="none"
						stroke="currentColor"
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="16"></line></svg
				>
			</button>
			<button
				class="inline-grid w-9 place-items-center text-zinc-800 hover:bg-amber-400 hover:text-amber-950 focus-visible:bg-amber-400 focus-visible:text-amber-950 focus-visible:outline-none data-copied:bg-green-500 data-copied:text-white"
				type="button"
				data-code-block-copy
				aria-label="Copy code"
				title="Copy code"
			>
				<svg
					class="size-4"
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 256 256"
					aria-hidden="true"
					><rect width="256" height="256" fill="none"></rect><polyline
						points="168 168 216 168 216 40 88 40 88 88"
						fill="none"
						stroke="currentColor"
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="16"></polyline><rect
						x="40"
						y="88"
						width="128"
						height="128"
						fill="none"
						stroke="currentColor"
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="16"></rect></svg
				>
			</button>
		</div>
	</div>
	<pre
		{...attrs}
		class:list={[
			classes,
			"m-0 overflow-x-auto p-4 font-mono text-[0.86rem] leading-[1.65] [tab-size:2] group-data-[wrap]:overflow-x-visible group-data-[wrap]:whitespace-pre-wrap group-data-[wrap]:break-words [&_code]:block [&_code]:min-w-max [&_code]:p-0 group-data-[wrap]:[&_code]:min-w-0 group-data-[wrap]:[&_code]:whitespace-inherit",
		]}
		style={style}
	><slot /></pre>
</figure>

<script>
	function enhanceCodeBlocks() {
		const blocks = document.querySelectorAll(".code-block");

		for (const block of blocks) {
			if (!(block instanceof HTMLElement) || block.hasAttribute("data-code-block-ready")) {
				continue;
			}

			const pre = block.querySelector("pre");
			const code = pre?.querySelector("code");
			const label = block.querySelector("[data-code-block-label]");
			const copyButton = block.querySelector<HTMLButtonElement>("[data-code-block-copy]");
			const wrapButton = block.querySelector<HTMLButtonElement>("[data-code-block-wrap]");
			const hasFilename = block.hasAttribute("data-code-block-filename");
			const language =
				pre?.dataset.language ||
				[...(code?.classList ?? [])]
					.find((className) => className.startsWith("language-"))
					?.replace("language-", "");

			if (label instanceof HTMLElement && language && !hasFilename) {
				label.textContent = language;
			}

			block.setAttribute("data-code-block-ready", "true");

			wrapButton?.addEventListener("click", () => {
				const shouldWrap = !block.hasAttribute("data-wrap");

				block.toggleAttribute("data-wrap", shouldWrap);
				wrapButton.setAttribute("aria-pressed", String(shouldWrap));
				wrapButton.setAttribute("aria-label", shouldWrap ? "Disable line wrap" : "Wrap lines");
				wrapButton.setAttribute("title", shouldWrap ? "Disable line wrap" : "Wrap lines");
			});

			copyButton?.addEventListener("click", async () => {
				const text = code?.textContent ?? "";

				if (!text || !navigator.clipboard) return;

				await navigator.clipboard.writeText(text);
				copyButton.setAttribute("aria-label", "Copied");
				copyButton.setAttribute("title", "Copied");
				copyButton.setAttribute("data-copied", "true");

				window.setTimeout(() => {
					copyButton.setAttribute("aria-label", "Copy code");
					copyButton.setAttribute("title", "Copy code");
					copyButton.removeAttribute("data-copied");
				}, 1600);
			});
		}
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", enhanceCodeBlocks);
	} else {
		enhanceCodeBlocks();
	}
</script>
