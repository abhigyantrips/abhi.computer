---
import "@hackernoon/pixel-icon-library/fonts/iconfont.css";
import Logo from "@/components/logo.astro";
---

<header class="flex w-full items-center justify-between p-6 lg:px-8">
	<a
		href="/"
		class="p-1 no-underline!"
	>
		<Logo class="h-5 w-auto" />
	</a>

	<div class="flex items-center space-x-6">
		<a
			href="/links"
			class="uppercase"
			>Links</a
		>
		<a
			href="/things"
			class="uppercase"
			>Things</a
		>
		<a
			href="https://github.com/abhigyantrips"
			class="size-8 p-1 no-underline!"
			style="image-rendering: pixelated;"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 256 256"
				><rect
					width="256"
					height="256"
					fill="none"
				></rect><path
					d="M119.83,56A52,52,0,0,0,76,32a51.92,51.92,0,0,0-3.49,44.7A49.28,49.28,0,0,0,64,104v8a48,48,0,0,0,48,48h48a48,48,0,0,0,48-48v-8a49.28,49.28,0,0,0-8.51-27.3A51.92,51.92,0,0,0,196,32a52,52,0,0,0-43.83,24Z"
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="16"
				></path><path
					d="M104,232V192a32,32,0,0,1,32-32h0a32,32,0,0,1,32,32v40"
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="16"
				></path><path
					d="M104,208H72a32,32,0,0,1-32-32A32,32,0,0,0,8,144"
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="16"
				></path></svg
			>
		</a>
	</div>
</header>
